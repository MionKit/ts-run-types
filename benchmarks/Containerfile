# syntax=podman
# -----------------------------------------------------------------------------
# Isolated environment for the validation benchmarks. EACH competitor is a
# STANDALONE pnpm project (its own pnpm-workspace.yaml policy + package.json ->
# its own node_modules), so one competitor's dependency tree -- notably typia's
# heavy/fragile vite6+rollup4 -- can never break another's install or build.
#
# DEPS-ONLY IMAGE: this image bakes THIRD-PARTY node_modules ONLY. No first-party
# benchmark code lives here -- the shared suite, the per-competitor source, the
# typecost runner and aggregate.mjs are all BIND-MOUNTED at run time (see
# scripts/benchmarks.sh:mount_args), as is the ts-runtypes Go binary + the
# first-party packages. The package-manager manifests come from _deps/ (kept out
# of the host project roots so nobody can accidentally `pnpm install` there).
# Consequence: the image changes ONLY when a dependency manifest changes; source
# edits never invalidate it.
# -----------------------------------------------------------------------------
# Node 26 unflags the global `Temporal` API, so the benchmark suites use native
# Temporal — no temporal-polyfill shim — and timings run on the same runtime the
# published library targets. Pinned to the official Node 26 image; override
# BASE_IMAGE to build from a mirror / air-gapped registry.
ARG BASE_IMAGE=node:26-bookworm-slim
FROM ${BASE_IMAGE}

LABEL org.opencontainers.image.source=https://github.com/MionKit/ts-runtypes
LABEL org.opencontainers.image.description="ts-runtypes validation benchmarks - deps-only image (source bind-mounted at run time)"

ENV DO_NOT_TRACK=1
WORKDIR /app

# -- Trust extra CA certs (corporate / MITM egress proxy) ---------------------
# MUST precede every network step (npm/pnpm). The .cacerts/ dir is always present
# in the build context (scripts/benchmarks.sh creates it) but empty unless a proxy
# CA was supplied, so this is a no-op on a normal build.
COPY .cacerts/ /usr/local/share/ca-certificates/
RUN update-ca-certificates >/dev/null 2>&1 || true
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt

# Node 26 dropped the bundled corepack shim (it ships only npm), so install the
# repo-pinned pnpm globally — deterministic and baked into the image, so a pulled
# image needs no first-run package-manager download.
ARG PNPM_VERSION=11.1.1
RUN npm install -g pnpm@${PNPM_VERSION}

# -- Per-competitor installs --------------------------------------------------
# Each competitor gets a COPY of the supply-chain policy (pnpm-workspace.yaml +
# .npmrc) INTO ITS OWN DIR so `pnpm install` resolves there (no /app-level
# workspace file -- that would make pnpm treat /app as the root, find "no
# projects", and install nothing). node_modules is cached on each package.json.
# Manifests are sourced from _deps/ (the deps source-of-truth; absent from the
# host project roots). typia's install is non-fatal so its opt-in fragile deps
# can't abort the build.
COPY _deps/pnpm-workspace.yaml _deps/.npmrc competitors/zod/
COPY _deps/competitors/zod/package.json competitors/zod/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd competitors/zod && pnpm install --no-frozen-lockfile

COPY _deps/pnpm-workspace.yaml _deps/.npmrc competitors/typebox/
COPY _deps/competitors/typebox/package.json competitors/typebox/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd competitors/typebox && pnpm install --no-frozen-lockfile

COPY _deps/pnpm-workspace.yaml _deps/.npmrc competitors/ajv/
COPY _deps/competitors/ajv/package.json competitors/ajv/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd competitors/ajv && pnpm install --no-frozen-lockfile

COPY _deps/pnpm-workspace.yaml _deps/.npmrc competitors/ts-runtypes/
COPY _deps/competitors/ts-runtypes/package.json competitors/ts-runtypes/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd competitors/ts-runtypes && pnpm install --no-frozen-lockfile

COPY _deps/pnpm-workspace.yaml _deps/.npmrc competitors/typia/
COPY _deps/competitors/typia/package.json competitors/typia/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd competitors/typia && pnpm install --no-frozen-lockfile \
    || echo ">> typia install failed — its column degrades gracefully (left blank that run; BENCH_NO_TYPIA=1 skips it)"

# typecost runner -- its own TypeScript install (it drives the compiler API). The
# marker package it type-resolves against is the one bind-mounted into the ts-go
# competitor at run time (see scripts/benchmarks.sh:mount_args).
COPY _deps/pnpm-workspace.yaml _deps/.npmrc typecost/
COPY _deps/typecost/package.json typecost/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd typecost && pnpm install --no-frozen-lockfile

# No source COPY and no CMD: scripts/benchmarks.sh bind-mounts the benchmark
# source (shared/, competitors/*/ source files, typecost/*, aggregate.mjs) and
# supplies per-competitor build+run commands. typia's first ttsc build compiles
# its native Go plugin (~200s) into competitors/typia/node_modules/.ttsc/ at run
# time; that subpath is a persisted named volume so the compile happens once.

# Go
/bin/
*.test
*.out
*.prof
coverage.txt

# Node
node_modules/
packages/*/node_modules/
packages/*/dist/
packages/*/.dist/
packages/*/.coverage/
dist/
.dist/
.coverage/
*.tsbuildinfo
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# AI-enrichment generation suite — synthesized temp module files
# (recreated + cleaned per run by test/util/enrichGen.ts).
packages/ts-runtypes/test/suites/enrich/.tmp/

# Build / pack artefacts
/runtypes-cache.json
/tarballs/
# Cross-compiled per-platform binary packages, staged for publish by
# scripts/release/build-binaries.mjs (assembled, never committed).
/dist-binaries/
# Host-built playground WASM cache: the raw .wasm (buildid oracle + Node test
# resolver) + the ts-runtypes source overlay, produced by
# container/website/scripts/build-playground.sh. Large + reproducible; the browser
# copies are staged into container/website/public/playground-app/ (also ignored).
/.cache/rt-wasm/

# Consumer e2e fixture install artifacts (the fixture source IS tracked).
/pre-publish-e2e/package-lock.json
/logs/
/gendocs/

# Benchmark output (raw harness logs; aggregated summaries live in docs/)
/bench/results/
/container/benchmarks/results/

# Generated benchmark/test result JSON the docs website reads (read-only mount)
/.docdata/

# Stale leftovers from the container-website/ -> container/website/ rename:
# generated build output (.output) and bench artifacts. Nothing tracked or any
# current script writes here (the live paths live under container/), so these
# are disposable; ignore them rather than churn the working tree.
/container-website/
/container-benchmarks/

# IDE / editor
# Track shared workspace settings/extensions, ignore user-specific files.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store

# Local env
.env
.env.local
*.log

# Claude Code local (per-developer) settings
.claude/settings.local.json

# Claude Code agent worktrees (transient, auto-cleaned isolated checkouts)
.claude/worktrees/

# vite config timestamp artifacts
*.timestamp-*.mjs

# RunTypes files-mode output. In a CONSUMER project `__runtypes/types/` is
# gitignored (auto-written .gitignore) and `__runtypes/enriched/` is committed.
# In THIS repo the marker package's own test suite writes a __runtypes/ tree as
# a build artifact — ignore it wholesale so test runs never dirty the tree.
# (The `__` prefix keeps it clear of the hand-authored src/runtypes/ source.)
/packages/ts-runtypes/__runtypes/
# Cross-bundler real-build test fixtures (created + cleaned per run).
/packages/ts-runtypes/test/tmp-build-*/

# playwright-cli session artifacts (snapshots, traces, screenshots)
.playwright-cli/

# Go
/bin/
*.test
*.out
*.prof
coverage.txt

# Node
node_modules/
packages/*/node_modules/
packages/*/dist/
packages/*/.dist/
packages/*/.coverage/
dist/
.dist/
.coverage/
.nx/
*.tsbuildinfo
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# AI-enrichment generation suite — synthesized temp module files
# (recreated + cleaned per run by test/util/enrichmentGen.ts).
packages/ts-runtypes/test/suites/enrichment/.tmp/

# Build / pack artefacts
/runtypes-cache.json
/tarballs/
# Cross-compiled per-platform binary packages, staged for publish by
# scripts/build-binary-packages.mjs (assembled, never committed).
/dist-binaries/

# Consumer e2e fixture install artifacts (the fixture source IS tracked).
/e2e/package-lock.json
/logs/
/gendocs/

# Benchmark output (raw harness logs; aggregated summaries live in docs/)
/bench/results/
/container-benchmarks/results/

# Generated benchmark/test result JSON the docs website reads (read-only mount)
/.docdata/

# IDE / editor
# Track shared workspace settings/extensions, ignore user-specific files.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store

# Local env
.env
.env.local
*.log

# Claude Code local (per-developer) settings
.claude/settings.local.json

# vite config timestamp artifacts
*.timestamp-*.mjs

# RunTypes files-mode output. In a CONSUMER project `runtypes/types/` is
# gitignored (auto-written .gitignore) and `runtypes/enriched/` is committed.
# In THIS repo the marker package's own test suite writes a runtypes/ tree as
# a build artifact — ignore it wholesale so test runs never dirty the tree.
/packages/ts-runtypes/runtypes/

# playwright-cli session artifacts (snapshots, traces, screenshots)
.playwright-cli/

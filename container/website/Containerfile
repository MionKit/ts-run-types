# syntax=podman
# -----------------------------------------------------------------------------
# Single isolated build/run environment for BOTH the docs website (Nuxt + Docus)
# AND the validation benchmarks. One image, so CI can pull it once and build the
# whole site end-to-end (the site renders benchmark data produced by the same
# image), with no second image to keep in sync.
#
# DEPS-ONLY IMAGE: only the package-manager manifests are baked. The website's
# come from _deps/; the benchmarks' come from .bench-deps/ (a build-time copy of
# container/benchmarks/_deps/ that scripts/website/site.sh stages into the build context). The
# heavy node_modules trees are installed INSIDE the image. No first-party file
# lives here: the website source + its Nuxt/TS/ESLint config, and all benchmark
# source, are bind-mounted at run time (scripts/website/site.sh, scripts/website/bench-data/bench.sh).
# The image is invalidated only when a dependency manifest changes.
#
# TWO SEPARATE DEPENDENCY TREES, in separate dirs, each with its own node_modules:
#   /app    website deps (Nuxt/Docus). WORKDIR for website commands.
#   /bench  benchmark deps: /bench/competitors/<name> + /bench/typecost. Each is
#           its OWN isolated pnpm project (own node_modules), so one competitor's
#           heavy/fragile tree (notably typia) can never break another's install
#           or build. WORKDIR for benchmark commands.
# -----------------------------------------------------------------------------
# Node 26 unflags the global `Temporal` API, so the docs build and the benchmark
# suites run against the same runtime the published library targets, with no
# temporal-polyfill shim. Pinned to the official Node 26 image; override
# BASE_IMAGE to build from a mirror / air-gapped registry.
ARG BASE_IMAGE=node:26-bookworm
FROM ${BASE_IMAGE}

LABEL org.opencontainers.image.source=https://github.com/MionKit/ts-runtypes
LABEL org.opencontainers.image.description="ts-runtypes docs website + benchmarks - deps-only image (website at /app, benchmarks at /bench; first-party source bind-mounted at run time)"

ENV NUXT_TELEMETRY_DISABLED=1 \
    DO_NOT_TRACK=1

WORKDIR /app

# -- Optional: trust extra CA certs (corporate / MITM egress proxy) -----------
# MUST come before any network step (npm/apt/pnpm). The .cacerts/ dir is ALWAYS
# present in the build context (scripts/website/site.sh creates it) but is empty unless
# a proxy CA was supplied, in which case the script copies it in. An empty dir
# makes update-ca-certificates a no-op, so this layer costs nothing on a normal build.
COPY .cacerts/ /usr/local/share/ca-certificates/
RUN update-ca-certificates >/dev/null 2>&1 || true
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/ca-certificates.crt

# Node 26 dropped the bundled corepack shim (it ships only npm), so install the
# repo-pinned pnpm globally. Pinning keeps it deterministic and bakes pnpm into
# the image, so a pulled image needs no first-run package-manager download.
ARG PNPM_VERSION=11.1.1
RUN npm install -g pnpm@${PNPM_VERSION}

# better-sqlite3 (pulled by @nuxt/content) has no prebuilt binary for the new
# Node 26 ABI yet, so node-gyp compiles it from source at install time, which
# needs python3 + a C/C++ toolchain. The base lacks them; install only when
# missing so a fuller base that already bundles them stays a no-op.
RUN if ! command -v g++ >/dev/null 2>&1 || ! command -v python3 >/dev/null 2>&1 || ! command -v make >/dev/null 2>&1; then \
        apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends python3 make g++ \
        && rm -rf /var/lib/apt/lists/*; \
    fi

# == Website deps (/app) ======================================================
# Copy only the package-manager manifests so the dependency graph + lockfile are
# the cache key: editing website source/config never invalidates the install
# layer. The Nuxt/TS/ESLint config is bind-mounted at run time, not baked.
COPY _deps/package.json _deps/pnpm-lock.yaml _deps/pnpm-workspace.yaml _deps/.npmrc ./
# Install with the frozen lockfile under the workspace supply-chain policy
# (ignoreScripts + allowBuilds allowlist live in pnpm-workspace.yaml).
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# == Benchmark deps (/bench) ==================================================
# Each competitor + the typecost runner installs in its OWN dir so `pnpm install`
# resolves there (no /bench-level workspace file: that would make pnpm treat
# /bench as the root, find "no projects", and install nothing). Each gets a copy
# of the supply-chain policy (pnpm-workspace.yaml + .npmrc) plus its package.json.
# Manifests are sourced from .bench-deps/ (a build-time copy of container/benchmarks/_deps/,
# staged by scripts/website/site.sh). typia's install is non-fatal so its opt-in
# fragile deps can't abort the build. node_modules is cached on each package.json.
COPY .bench-deps/pnpm-workspace.yaml .bench-deps/.npmrc /bench/competitors/zod/
COPY .bench-deps/competitors/zod/package.json /bench/competitors/zod/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd /bench/competitors/zod && pnpm install --no-frozen-lockfile

COPY .bench-deps/pnpm-workspace.yaml .bench-deps/.npmrc /bench/competitors/typebox/
COPY .bench-deps/competitors/typebox/package.json /bench/competitors/typebox/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd /bench/competitors/typebox && pnpm install --no-frozen-lockfile

COPY .bench-deps/pnpm-workspace.yaml .bench-deps/.npmrc /bench/competitors/ajv/
COPY .bench-deps/competitors/ajv/package.json /bench/competitors/ajv/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd /bench/competitors/ajv && pnpm install --no-frozen-lockfile

COPY .bench-deps/pnpm-workspace.yaml .bench-deps/.npmrc /bench/competitors/ts-runtypes/
COPY .bench-deps/competitors/ts-runtypes/package.json /bench/competitors/ts-runtypes/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd /bench/competitors/ts-runtypes && pnpm install --no-frozen-lockfile

COPY .bench-deps/pnpm-workspace.yaml .bench-deps/.npmrc /bench/competitors/typia/
COPY .bench-deps/competitors/typia/package.json /bench/competitors/typia/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd /bench/competitors/typia && pnpm install --no-frozen-lockfile \
    || echo ">> typia install failed; its column degrades gracefully (left blank that run; RT_BENCH_NO_TYPIA=1 skips it)"

# Pre-compile typia's native ttsc plugin so node_modules/.ttsc is BAKED into the
# image. Otherwise it compiles (~90-200s) at the first runtime build. The plugin is
# keyed on typia's version (not the caller's types), so a trivial probe warms it and
# the real bench build reuses it. Needs network (downloads ttsc's embedded Go
# toolchain) - available during build. Non-fatal: on failure typia just recompiles
# the plugin at runtime, exactly as before.
RUN cd /bench/competitors/typia \
 && printf 'import typia from "typia";\nexport const _ttscWarm = typia.createIs<{ a: number; b: string }>();\n' > .ttsc-warm.ts \
 && printf '{"compilerOptions":{"strict":true,"plugins":[{"transform":"typia/lib/transform"}]},"include":[".ttsc-warm.ts"]}' > tsconfig.ttsc-warm.json \
 && node --input-type=module -e 'import {build} from "esbuild"; import ttsc from "@ttsc/unplugin/esbuild"; await build({entryPoints:[".ttsc-warm.ts"],bundle:true,write:false,format:"esm",platform:"node",target:"node22",logLevel:"info",tsconfig:"tsconfig.ttsc-warm.json",plugins:[ttsc({project:"tsconfig.ttsc-warm.json"})]});' \
 && rm -f .ttsc-warm.ts tsconfig.ttsc-warm.json \
 && test -d node_modules/.ttsc \
 || echo ">> ttsc warm skipped/failed; typia recompiles its plugin at the first runtime build"

# typecost runner: its own TypeScript install (it drives the compiler API). The
# marker package it type-resolves against is bind-mounted into the ts-runtypes
# competitor at run time (see scripts/website/bench-data/bench.sh:mount_args).
COPY .bench-deps/pnpm-workspace.yaml .bench-deps/.npmrc /bench/typecost/
COPY .bench-deps/typecost/package.json /bench/typecost/package.json
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd /bench/typecost && pnpm install --no-frozen-lockfile

# == Pre-publish e2e: verdaccio registry + builder toolchains (/e2e) ==========
# The pre-publish e2e (docs/todos/prepublish-e2e-*.md) runs a containerized
# verdaccio + a multi-bundler feature matrix in this SAME shared image, so a
# maintainer can smoke a release locally and CI's Linux lane reuses the one
# pulled image. verdaccio is a node app (fits the Node 26 base); running the
# untrusted registry + its dependency tree INSIDE the rootless container (never
# on a dev's host) is the supply-chain point of the design.
RUN npm install -g verdaccio@6.7.2

# The e2e builder toolchains (rolldown-vite, esbuild, rollup, rolldown, webpack,
# rspack, oxlint, eslint + the TS parser/loaders), baked under /e2e exactly like
# the benchmark competitors. Each e2e run installs ONLY the changing
# @ts-runtypes/* from verdaccio on top of this node_modules; the e2e's own
# apps/test are bind-mounted at run time. Manifests come from .e2e-deps/ (a
# build-time copy of container/pre-publish-e2e/_deps/, staged by image.mjs).
COPY .e2e-deps/package.json .e2e-deps/pnpm-workspace.yaml .e2e-deps/.npmrc /e2e/
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    cd /e2e && pnpm install --no-frozen-lockfile

# The registry config + serve script (starts verdaccio, publishes the mounted
# /tarballs in dependency order, signals readiness). Staged from
# container/pre-publish-e2e/registry/ by scripts/container/image.mjs. Kept LAST so
# a config tweak never invalidates the heavier toolchain-install layer above.
COPY .e2e-registry/verdaccio.yaml /etc/verdaccio/config.yaml
COPY .e2e-registry/e2e-serve.sh /usr/local/bin/e2e-serve.sh
RUN chmod +x /usr/local/bin/e2e-serve.sh

EXPOSE 3000

# No CMD: scripts/website/site.sh (WORKDIR /app) and scripts/website/bench-data/bench.sh (WORKDIR
# /bench) each bind-mount their first-party source and supply the command. typia's
# native ttsc plugin is pre-compiled into /bench/competitors/typia/node_modules/.ttsc
# above (baked into the image), so the bench build reuses it with no runtime compile.

# Installed at run time (verdaccio @ts-runtypes/* + baked toolchains on the host).
node_modules/
package-lock.json
# Per-app build output + the RunTypes plugin's generated cache modules.
apps/*/dist/
apps/*/.rt/
**/__runtypes/
# Enrichment mirrors — AUTOGENERATED by `ts-runtypes gen` during the e2e so the
# test exercises the generator (they land under the conventional
# src/__runtypes/enriched/, covered by the **/__runtypes/ ignore above). In a
# real project the enriched/ half IS committed; ignored here on purpose.
# Host-iteration scaffolding copied in from _deps for a local run.
/pnpm-workspace.yaml
/.npmrc
/pnpm-lock.yaml

# Extra CA certs injected for proxied image builds (never commit certs). The dir is
# recreated by scripts/container/image.mjs before every build; keep the .gitkeep.
.cacerts/*
!.cacerts/.gitkeep

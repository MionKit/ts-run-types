{
  // The shared library's tsconfig. @ts-runtypes/* resolves from node_modules
  // (verdaccio-installed in-container; a workspace symlink for host iteration) —
  // no workspace `paths`, so `ts-runtypes gen`/`check` and every bundler resolve
  // it identically to a real consumer. rootDir=src anchors the enrichment mirror
  // paths (src/models/x.ts -> runtypes/generated/{friendly,mock}/models/x.ts).
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": "src",
    "types": [],
    "plugins": [
      {
        "name": "ts-runtypes",
        "enrichDir": "runtypes/generated",
        "i18n": {"sourceLocale": "en", "locales": ["es"]}
      }
    ]
  },
  "include": ["src"]
}

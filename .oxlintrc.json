{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error"
  },
  "plugins": ["typescript", "oxc", "unicorn"],
  "jsPlugins": ["./packages/runtypes-devtools/dist/eslint/index.js"],
  "rules": {
    "runtypes/no-enrichment-todo": "error",
    "runtypes/no-orphan-carcass": "error",
    "runtypes/enrichment-field": "error",
    "runtypes/enrichment-drift": "error",
    "no-empty-function": "off",
    "typescript/no-empty-function": "off",
    "typescript/no-explicit-any": "off",
    "typescript/no-empty-object-type": "error"
  },
  "settings": {
    "runtypes": {
      "binary": "./bin/ts-runtypes"
    }
  },
  "ignorePatterns": [
    "node_modules/**",
    "third_party/**",
    "**/dist/**",
    "**/.dist/**",
    "**/coverage/**",
    "**/.coverage/**",
    "**/.nx/**",
    "**/test/**",
    "packages/examples/**",
    "packages/ts-runtypes/src/caches/**",
    "container/**",
    "docs/**",
    "bin/**",
    "internal/**",
    "scripts/**",
    "benchmarks/**",
    ".claude/**",
    "**/vite.config.ts",
    "**/vitest.config.ts",
    "**/vitest.workspace.ts",
    "eslint.config.js"
  ]
}

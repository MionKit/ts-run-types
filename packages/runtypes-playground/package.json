{
  "name": "runtypes-playground",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Embeddable in-browser ts-runtypes playground: a framework-agnostic engine + a <runtypes-playground> web component that resolves AND executes generated functions live via the WASM resolver.",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "source": "./src/core/index.ts",
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./element": {
      "source": "./src/element/index.ts",
      "types": "./dist/element/index.d.ts",
      "import": "./dist/element/index.js"
    },
    "./assets/*": "./assets/*"
  },
  "files": ["dist", "src", "assets"],
  "scripts": {
    "build:wasm": "bash scripts/build-wasm.sh",
    "build": "tsc --build tsconfig.json",
    "build:site": "vite build",
    "build:all": "pnpm run build:wasm && pnpm run build:site",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "demo": "vite",
    "format": "oxfmt --write 'src/**/*.ts'",
    "clean": "node ../../scripts/rmrf.mjs dist dist-site tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "monaco-editor": "0.52.2",
    "prettier": "3.8.2",
    "ts-runtypes": "workspace:*"
  }
}

{
  // The CommonJS half of @ts-runtypes/core's dual build. The ESM build
  // (tsconfig.json) emits dist/*.js as ES modules; this pass re-emits the same src
  // as CommonJS into dist/cjs/. A { "type": "commonjs" } marker (written by
  // scripts/lib/emit-cjs-pkg.mjs) makes Node read dist/cjs/*.js as CommonJS even
  // though the package root is type:module. exports."require" points here.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    // commonjs emit requires the classic node10 resolution; TS 6 deprecates it but
    // it is the only resolution valid with module:commonjs, so opt in explicitly.
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "outDir": "dist/cjs",
    // Not a project reference here, so no composite/declaration/build-info.
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "incremental": false,
    "sourceMap": false
  }
}

{
  "name": "ts-runtypes",
  "version": "0.1.0",
  "description": "Sentinel marker + canonical reflection helper for ts-runtypes. The vite plugin rewrites every call of a function whose trailing parameter type is InjectRunTypeId<T> exported from this package.",
  "type": "module",
  "license": "UNLICENSED",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./caches/runTypesCache": {
      "source": "./src/caches/runTypesCache.ts",
      "types": "./dist/caches/runTypesCache.d.ts",
      "import": "./dist/caches/runTypesCache.js",
      "require": "./dist/caches/runTypesCache.cjs"
    },
    "./caches/isTypeCache": {
      "source": "./src/caches/isTypeCache.ts",
      "types": "./dist/caches/isTypeCache.d.ts",
      "import": "./dist/caches/isTypeCache.js",
      "require": "./dist/caches/isTypeCache.cjs"
    },
    "./caches/pureFnsCache": {
      "source": "./src/caches/pureFnsCache.ts",
      "types": "./dist/caches/pureFnsCache.d.ts",
      "import": "./dist/caches/pureFnsCache.js",
      "require": "./dist/caches/pureFnsCache.cjs"
    },
    "./formats": {
      "source": "./src/formats/index.ts",
      "types": "./dist/formats/index.d.ts",
      "import": "./dist/formats/index.js",
      "require": "./dist/formats/index.cjs"
    },
    "./formats/temporal": {
      "source": "./src/formats/datetime/temporalFormats.ts",
      "types": "./dist/formats/datetime/temporalFormats.d.ts",
      "import": "./dist/formats/datetime/temporalFormats.js",
      "require": "./dist/formats/datetime/temporalFormats.cjs"
    },
    "./schema": {
      "source": "./src/schema/index.ts",
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "require": "./dist/schema/index.cjs"
    }
  },
  "bin": {
    "ts-runtypes-skills": "./bin/skills.mjs"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mionkit/ts-runtypes.git",
    "directory": "packages/runtypes"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "pretest": "pnpm --filter runtypes-devtools run build",
    "test": "vitest run",
    "dev:test": "vitest watch",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.ts'",
    "clean": "rimraf dist .coverage tsconfig.tsbuildinfo",
    "fresh-start": "pnpm run clean && rimraf node_modules"
  },
  "devDependencies": {
    "runtypes-devtools": "workspace:*"
  }
}

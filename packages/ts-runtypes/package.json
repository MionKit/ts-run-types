{
  "name": "@ts-runtypes/core",
  "version": "0.1.0",
  "description": "Sentinel marker + canonical reflection helper for ts-runtypes. The vite plugin rewrites every call of a function whose trailing parameter type is InjectRunTypeId<T> exported from this package.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./caches/runTypesCache": {
      "source": "./src/caches/runTypesCache.ts",
      "types": "./dist/caches/runTypesCache.d.ts",
      "import": "./dist/caches/runTypesCache.js",
      "require": "./dist/cjs/caches/runTypesCache.js"
    },
    "./caches/isTypeCache": {
      "source": "./src/caches/isTypeCache.ts",
      "types": "./dist/caches/isTypeCache.d.ts",
      "import": "./dist/caches/isTypeCache.js",
      "require": "./dist/cjs/caches/isTypeCache.js"
    },
    "./caches/pureFnsCache": {
      "source": "./src/caches/pureFnsCache.ts",
      "types": "./dist/caches/pureFnsCache.d.ts",
      "import": "./dist/caches/pureFnsCache.js",
      "require": "./dist/cjs/caches/pureFnsCache.js"
    },
    "./formats": {
      "source": "./src/formats/index.ts",
      "types": "./dist/formats/index.d.ts",
      "import": "./dist/formats/index.js",
      "require": "./dist/cjs/formats/index.js"
    },
    "./formats/temporal": {
      "source": "./src/formats/datetime/temporalFormats.ts",
      "types": "./dist/formats/datetime/temporalFormats.d.ts",
      "import": "./dist/formats/datetime/temporalFormats.js",
      "require": "./dist/cjs/formats/datetime/temporalFormats.js"
    },
    "./schema": {
      "source": "./src/schema/index.ts",
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "require": "./dist/cjs/schema/index.js"
    }
  },
  "bin": {
    "ts-runtypes-skills": "./bin/skills.mjs"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://runtypes.pages.dev",
  "bugs": {
    "url": "https://github.com/MionKit/ts-run-types/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/ts-run-types.git",
    "directory": "packages/ts-runtypes"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json && tsc -p tsconfig.cjs.json && node ../../scripts/lib/emit-cjs-pkg.mjs dist/cjs",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "pretest": "pnpm --filter @ts-runtypes/devtools run build",
    "test": "vitest run",
    "dev:test": "vitest watch",
    "clean": "node ../../scripts/lib/rmrf.mjs dist .coverage tsconfig.tsbuildinfo",
    "fresh-start": "pnpm run clean && node ../../scripts/lib/rmrf.mjs node_modules"
  },
  "devDependencies": {
    "@ts-runtypes/devtools": "workspace:*"
  }
}

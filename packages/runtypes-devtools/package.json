{
  "name": "runtypes-devtools",
  "version": "0.1.0",
  "description": "RunTypes devtools: cross-bundler plugin (Vite/Rollup/webpack/Rspack/esbuild) that rewrites RunTypes marker calls using the ts-runtypes resolver, plus future lint integrations.",
  "type": "module",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./unplugin": {
      "types": "./dist/unplugin.d.ts",
      "import": "./dist/unplugin.js"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js"
    },
    "./rspack": {
      "types": "./dist/rspack.d.ts",
      "import": "./dist/rspack.js"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "import": "./dist/eslint/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mionkit/ts-runtypes.git",
    "directory": "packages/runtypes-devtools"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "dev:test": "vitest watch",
    "format": "oxfmt --write 'src/**/*.ts'",
    "clean": "node ../../scripts/rmrf.mjs dist .coverage tsconfig.tsbuildinfo",
    "fresh-start": "pnpm run clean && node ../../scripts/rmrf.mjs node_modules"
  },
  "dependencies": {
    "ts-runtypes-bin": "workspace:*",
    "unplugin": "3.0.0"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "vite": "8.0.16"
  }
}

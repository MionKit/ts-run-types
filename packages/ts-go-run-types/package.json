{
  "name": "@mionjs/ts-go-run-types",
  "version": "0.1.0",
  "description": "Sentinel marker + canonical reflection helper for ts-run-types. The vite plugin rewrites every call of a function whose trailing parameter type is RuntypeId<T> exported from this package.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mionkit/ts-run-types.git",
    "directory": "packages/runtypes"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "dev:test": "vitest watch",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.ts'",
    "clean": "rimraf dist .coverage",
    "fresh-start": "pnpm run clean && rimraf node_modules"
  }
}

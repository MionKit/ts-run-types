{
  // Isolated type-graph budget probe for `DataOnly<T>`. Compiles ONLY the
  // DataOnly type-test (+ its import graph + the Temporal ambient) so
  // `tsc --extendedDiagnostics` reports an `Instantiations:` count dominated by
  // DataOnly's cost on the test matrix. Use as a quantitative regression guard:
  // a DataOnly change that balloons instantiation count (a near-miss to TS2589)
  // shows up here long before it trips the hard cap. Run:
  //   pnpm --filter @mionjs/ts-go-run-types run bench:dataonly-types
  // `incremental: false` forces a FULL check every run so the count is
  // deterministic (the inherited build config is `composite`/incremental).
  "extends": "./tsconfig.test.json",
  "compilerOptions": {
    "incremental": false,
    "composite": false
  },
  "include": ["test/types/dataonly.type-test.ts", "test/temporal-ambient.d.ts"]
}

{
  "name": "vite-plugin-runtypes",
  "version": "0.1.0",
  "description": "Vite plugin that rewrites RunTypes marker calls using the ts-runtypes resolver.",
  "type": "module",
  "license": "UNLICENSED",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mionkit/ts-runtypes.git",
    "directory": "packages/vite-plugin-runtypes"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "test": "vitest run",
    "dev:test": "vitest watch",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.ts'",
    "clean": "rimraf dist .coverage tsconfig.tsbuildinfo",
    "fresh-start": "pnpm run clean && rimraf node_modules"
  },
  "dependencies": {
    "ts-runtypes-bin": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "vite": "5.4.10"
  }
}

{
  "jsPlugins": [
    "./dist/eslint/index.js"
  ],
  "rules": {
    "runtypes/broken-tsconfig": "error",
    "runtypes/invalid-marker": "error",
    "runtypes/redundant-marker": "warn",
    "runtypes/pure-functions": "error",
    "runtypes/validate-non-serializable": "error",
    "runtypes/validate-skipped-member": "warn",
    "runtypes/json-non-serializable": "error",
    "runtypes/json-skipped-member": "warn",
    "runtypes/binary-non-serializable": "error",
    "runtypes/binary-skipped-member": "warn",
    "runtypes/clone-unsupported-type": "error",
    "runtypes/clone-shared-reference": "warn",
    "runtypes/unknown-keys": "warn",
    "runtypes/format": "error",
    "runtypes/invalid-override": "error",
    "runtypes/override-side-effect": "warn",
    "runtypes/non-enumerable": "error",
    "runtypes/class-serializer": "warn",
    "runtypes/other": "error",
    "runtypes/no-enrichment-todo": "error",
    "runtypes/no-orphan-carcass": "error",
    "runtypes/enrichment-field": "error",
    "runtypes/enrichment-message": "warn",
    "runtypes/enrichment-broken-source": "error",
    "runtypes/enrichment-misplaced-file": "warn"
  }
}

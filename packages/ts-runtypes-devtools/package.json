{
  "name": "@ts-runtypes/devtools",
  "version": "0.1.0",
  "description": "RunTypes devtools: cross-bundler plugin (Vite/Rollup/Rolldown/webpack/Rspack/esbuild) that rewrites RunTypes marker calls using the ts-runtypes resolver, plus an OXlint/ESLint lint plugin.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./unplugin": {
      "types": "./dist/unplugin.d.ts",
      "import": "./dist/unplugin.js"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.js"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js"
    },
    "./rspack": {
      "types": "./dist/rspack.d.ts",
      "import": "./dist/rspack.js"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.js"
    },
    "./rolldown": {
      "types": "./dist/rolldown.d.ts",
      "import": "./dist/rolldown.js"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "import": "./dist/eslint/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://runtypes.pages.dev",
  "bugs": {
    "url": "https://github.com/MionKit/ts-run-types/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/ts-run-types.git",
    "directory": "packages/ts-runtypes-devtools"
  },
  "scripts": {
    "build": "tsc --build tsconfig.json",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "dev:test": "vitest watch",
    "clean": "node ../../scripts/lib/rmrf.mjs dist .coverage tsconfig.tsbuildinfo",
    "fresh-start": "pnpm run clean && node ../../scripts/lib/rmrf.mjs node_modules"
  },
  "dependencies": {
    "unplugin": "3.3.0"
  },
  "peerDependencies": {
    "@ts-runtypes/bin": "workspace:*",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ts-runtypes/bin": "workspace:*",
    "vite": "8.0.16"
  }
}

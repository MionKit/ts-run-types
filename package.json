{
  "name": "ts-runtypes-monorepo",
  "version": "0.9.2",
  "description": "Compile-time runtime-type resolver on TypeScript 7 / typescript-go (tsgo).",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "homepage": "https://runtypes.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MionKit/ts-run-types.git"
  },
  "bugs": {
    "url": "https://github.com/MionKit/ts-run-types/issues"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "ma-jerez",
  "engines": {
    "node": ">= 26.0.0",
    "pnpm": ">= 10.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "scripts": {
    "rtx": "node scripts/rt.mjs",
    "pretest": "pnpm run check:builds",
    "test": "vitest run",
    "check:builds": "node scripts/rt.mjs core build",
    "check:env": "node scripts/rt.mjs env",
    "gen:ts-constants": "go -C ts-go-runtypes run ./cmd/gen-ts-constants",
    "gen:run-type-kind": "go -C ts-go-runtypes run ./cmd/gen-run-type-kind > packages/ts-runtypes/src/runTypeKind.ts",
    "gen:fn-hashes": "go -C ts-go-runtypes run ./cmd/gen-fn-hashes > packages/ts-runtypes/src/fnHashes.generated.ts",
    "gen:diag-catalog": "node scripts/core/gen-diagnostics-catalog.mjs",
    "format": "oxfmt --write 'packages/**/*.ts' && prettier --write 'packages/**/*.md' && gofmt -w ts-go-runtypes/cmd ts-go-runtypes/internal",
    "check-format": "oxfmt --check 'packages/**/*.ts' && prettier --check 'packages/**/*.md' && gofmt -l ts-go-runtypes/cmd ts-go-runtypes/internal && test -z \"$(gofmt -l ts-go-runtypes/cmd ts-go-runtypes/internal)\"",
    "check-format-pre-commit": "oxfmt --check",
    "lint": "pnpm run lint:runtypes && pnpm run typecheck",
    "prelint:runtypes": "pnpm run check:builds",
    "lint:runtypes": "oxlint",
    "typecheck:test": "pnpm -r run typecheck:test",
    "typecheck": "pnpm run typecheck:test && tsc -p ts-go-runtypes/internal/testfixtures/tsconfig.json --noEmit && tsc -p ts-go-runtypes/internal/testfixtures/atomic/tsconfig.json --noEmit && tsc -p packages/examples/tsconfig.json",
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "fresh-start": "pnpm -r run fresh-start && node scripts/lib/rmrf.mjs node_modules && pnpm install --frozen-lockfile",
    "prepare": "husky",
    "commit": "cz",
    "changelog": "git-cliff -o CHANGELOG.md",
    "changelog:unreleased": "git-cliff --unreleased --prepend CHANGELOG.md"
  },
  "lint-staged": {
    "packages/**/!(*.spec|*.test|vitest.config|vite.config).ts": [
      "pnpm run check-format-pre-commit --"
    ],
    "packages/**/*.{spec,test}.ts": [
      "pnpm run check-format-pre-commit --"
    ],
    "**/*.ts": [
      "pnpm exec oxlint --no-error-on-unmatched-pattern"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@playwright/cli": "0.1.13",
    "@types/node": "26.1.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "prettier": "3.8.2",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}

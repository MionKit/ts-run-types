{
  "name": "ts-runtypes-monorepo",
  "version": "0.1.0",
  "description": "Compile-time runtime-type resolver on TypeScript 7 / typescript-go (tsgo).",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "homepage": "https://github.com/mionkit/ts-runtypes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mionkit/ts-runtypes.git"
  },
  "bugs": {
    "url": "https://github.com/mionkit/ts-runtypes/issues"
  },
  "license": "UNLICENSED",
  "author": "ma-jerez",
  "engines": {
    "node": ">= 24.0.0",
    "pnpm": ">= 10.0.0"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "scripts": {
    "pretest": "pnpm run check:builds",
    "test": "vitest run",
    "check:builds": "bash scripts/check-stale-builds.sh",
    "fuzz:unit": "vitest run --config packages/ts-runtypes/test/fuzz/vitest.fuzz-unit.config.ts",
    "prefuzz": "pnpm run check:builds",
    "fuzz": "vitest run fuzz.integration typeFuzz.integration binaryEncoderResize",
    "prefuzz:soak": "pnpm run check:builds",
    "fuzz:soak": "FUZZ_SOAK_MS=60000 vitest run fuzz.integration",
    "prefuzz:types": "pnpm run check:builds",
    "fuzz:types": "vitest run typeFuzz.integration",
    "prefuzz:types:soak": "pnpm run check:builds",
    "fuzz:types:soak": "FUZZ_TYPES_SOAK_MS=60000 vitest run typeFuzz.integration",
    "prets-runtypes:smoke": "pnpm run check:builds",
    "ts-runtypes:smoke": "node scripts/ts-runtypes-smoke.mjs",
    "predump:test-modules": "pnpm run check:builds",
    "dump:test-modules": "node scripts/dump-test-modules.mjs",
    "dump:test-modules:allSingle": "pnpm run dump:test-modules --module-mode allSingle",
    "dump:test-modules:allModules": "pnpm run dump:test-modules --module-mode allModules",
    "gen:ts-constants": "go run ./cmd/gen-ts-constants",
    "gen:run-type-kind": "go run ./cmd/gen-run-type-kind > packages/ts-runtypes/src/runTypeKind.ts",
    "pregen:validation-suite-json": "pnpm run check:builds",
    "gen:validation-suite-json": "node scripts/export-validation-suite.mjs",
    "pregen:serialization-suite-json": "pnpm run check:builds",
    "gen:serialization-suite-json": "node scripts/export-serialization-suite.mjs",
    "pregen:format-validation-suite-json": "pnpm run check:builds",
    "gen:format-validation-suite-json": "node scripts/export-validation-suite.mjs --suite format-validation",
    "pregen:format-serialization-suite-json": "pnpm run check:builds",
    "gen:format-serialization-suite-json": "node scripts/export-serialization-suite.mjs --suite format-serialization",
    "gen:website-suite-data": "node scripts/gen-website-suite-data.mjs",
    "gen:bench-docs": "node scripts/gen-bench-docs.mjs",
    "pregen:serialization-bench": "pnpm run check:builds",
    "gen:serialization-bench": "node scripts/gen-serialization-bench.mjs",
    "gen:suite-docs": "pnpm run gen:validation-suite-json && pnpm run gen:serialization-suite-json && pnpm run gen:format-validation-suite-json && pnpm run gen:format-serialization-suite-json && pnpm run gen:website-suite-data",
    "format": "prettier --write 'packages/**/*.{ts,md}'",
    "check-format": "prettier --check 'packages/**/*.{ts,md}'",
    "check-format-pre-commit": "prettier --check",
    "lint": "lerna run lint",
    "lint-pre-committ": "eslint --quiet",
    "typecheck:test": "lerna run typecheck:test",
    "build": "lerna run build",
    "podman-website:build-image": "bash scripts/podman-website.sh build-image",
    "podman-website:lock": "bash scripts/podman-website.sh lock",
    "podman-website:login": "bash scripts/podman-website.sh login",
    "podman-website:push": "bash scripts/podman-website.sh push",
    "podman-website:pull": "bash scripts/podman-website.sh pull",
    "podman-website:clean": "bash scripts/podman-website.sh clean",
    "website:dev": "bash scripts/website.sh dev",
    "website:dev:agent": "bash scripts/website.sh dev --isAgent",
    "website:build": "bash scripts/website.sh build",
    "website:generate": "bash scripts/website.sh generate",
    "website:serve": "node scripts/serve-website.mjs",
    "website:smoke": "bash scripts/website.sh smoke",
    "website:verify-docs": "bash scripts/website.sh verify-docs",
    "website:prep": "bash scripts/website.sh prep",
    "website:shell": "bash scripts/website.sh shell",
    "website:publish": "bash scripts/website-publish.sh",
    "website:publish:quick": "bash scripts/website-publish.sh --quick",
    "website:publish:no-bench": "bash scripts/website-publish.sh --no-bench",
    "bench:prep": "bash scripts/benchmarks.sh prep",
    "bench": "bash scripts/benchmarks.sh bench",
    "bench:one": "bash scripts/benchmarks.sh bench-one",
    "bench:full": "bash scripts/benchmarks.sh fullbench",
    "bench:serialization": "bash scripts/benchmarks.sh serialization",
    "bench:website": "bash scripts/benchmarks.sh website-bench",
    "bench:website:quick": "bash scripts/benchmarks.sh website-bench --quick",
    "bench:build": "bash scripts/benchmarks.sh build",
    "bench:smoke": "bash scripts/benchmarks.sh smoke",
    "bench:typecost": "bash scripts/benchmarks.sh typecost",
    "bench:compiletime": "bash scripts/benchmarks.sh compiletime",
    "bench:capture-env": "bash scripts/benchmarks.sh capture-env",
    "bench:shell": "bash scripts/benchmarks.sh shell",
    "bench:clean": "bash scripts/benchmarks.sh clean",
    "audit:alignment": "bash scripts/benchmarks.sh audit",
    "clean": "nx reset && lerna run clean",
    "fresh-start": "lerna run fresh-start && rimraf node_modules && pnpm install --frozen-lockfile",
    "prepare": "husky",
    "commit": "cz",
    "changelog": "git-cliff -o CHANGELOG.md",
    "changelog:unreleased": "git-cliff --unreleased --prepend CHANGELOG.md",
    "pre-publish-test": "bash scripts/pre-publish-test.sh",
    "npm-publish": "bash scripts/publish.sh",
    "npm-unpublish": "bash scripts/unpublish.sh"
  },
  "lint-staged": {
    "packages/**/!(*.spec|*.test|vitest.config|vite.config).ts": [
      "pnpm run lint-pre-committ --",
      "pnpm run check-format-pre-commit --"
    ],
    "packages/**/*.{spec,test}.ts": [
      "pnpm run check-format-pre-commit --"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@eslint/js": "9.39.4",
    "@playwright/cli": "0.1.13",
    "@types/node": "24.12.2",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lerna": "9.0.7",
    "lint-staged": "16.4.0",
    "nx": "22.4.4",
    "prettier": "3.8.2",
    "rimraf": "6.1.3",
    "temporal-polyfill": "0.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.1",
    "vitest": "2.1.9"
  }
}

# Local environment for the RunTypes container scripts.
#
# Copy to `.env` (git-ignored) and fill in what you need:
#     cp .env.example .env
#
# The repo-root `.env` is auto-loaded by the container scripts
# (scripts/podman-website.sh, scripts/website.sh, scripts/benchmarks.sh) via
# scripts/lib-container.sh + scripts/lib-ghcr.sh. Only UNCOMMENTED lines take
# effect, and `.env` is absent in CI (git-ignored), so it never affects GitHub
# Actions env/secrets.

# === GHCR: push / pull the shared website+benchmark image =====================
# A GitHub Personal Access Token. write:packages to push (pnpm run
# podman-website:push), read:packages to pull a private image (podman-website:pull).
# Inline:
# GHCR_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ...or point at a file that holds ONLY the token:
# GHCR_PAT_FILE=/absolute/path/to/ghcr-token.txt
#
# Registry coordinates (defaults shown; override only if they differ):
# GHCR_OWNER=mionkit
# GHCR_USER=your-github-username

# === Image source (optional) ==================================================
# Force a LOCAL image build instead of pulling the published image from GHCR:
# WEBSITE_USE_LOCAL=1   # scripts/website.sh + scripts/podman-website.sh
# BENCH_USE_LOCAL=1     # scripts/benchmarks.sh

# === Benchmark knobs (optional) ===============================================
# BENCH_NO_TYPIA=1      # skip the typia competitor (its native plugin build)
# BENCH_QUICK=1         # fast / preview numbers (noisy, not for publishing)

# NOTE: CI-only secrets - NPM_TOKEN, CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID -
# live in GitHub repo / Environment secrets, NOT here. This file is local only.

# RunTypes local environment. Copy this file to `.env` and fill in the values:
#     cp .env.sample .env
#
# `.env` (git-ignored) is auto-loaded from the repo root by the container scripts
# (scripts/podman-website.sh, scripts/website.sh, scripts/benchmarks.sh). CI has no
# .env, so it never affects GitHub Actions env/secrets.

# --- GHCR: push / pull the shared website+benchmark image --------------------
# GitHub PAT: write:packages to push (pnpm run podman-website:push), read:packages
# to pull a private image. Set GHCR_PAT inline, OR point GHCR_PAT_FILE at a file
# that holds only the token (used when GHCR_PAT is blank).
GHCR_PAT=
GHCR_PAT_FILE=

# Registry coordinates (defaults already target this repo; GHCR_USER is cosmetic,
# the PAT is what authenticates).
GHCR_OWNER=mionkit
GHCR_USER=

# --- Optional toggles (uncomment to enable; 1 = on) --------------------------
# Force a LOCAL image build instead of pulling the published image from GHCR:
# WEBSITE_USE_LOCAL=1
# BENCH_USE_LOCAL=1
# Skip the typia competitor / use fast preview benchmark numbers:
# BENCH_NO_TYPIA=1
# BENCH_QUICK=1

# NOTE: CI-only secrets - NPM_TOKEN, CLOUDFLARE_API_TOKEN, CLOUDFLARE_ACCOUNT_ID -
# live in GitHub repo / Environment secrets, NOT here.

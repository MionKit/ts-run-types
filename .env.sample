# RunTypes local environment. Copy this file to `.env` and fill in what you need:
#     cp .env.sample .env        (or: pnpm run check:env --create-env)
#
# `.env` (git-ignored) is auto-loaded from the repo root by the project scripts
# (container scripts, build.sh, the publish scripts). CI has no `.env`, so
# it never affects GitHub Actions. Inspect it with `pnpm run check:env`.
#
# This file lists the USER-SETTABLE vars only: the secrets you need for a given task
# plus the overridable knobs (all have defaults, so they stay commented out). The
# complete registry, including the internal/protocol vars the scripts set themselves,
# lives in scripts/lib/env.mjs (REGISTRY) and is printed by `pnpm run check:env`.
# Never add an internal var here - setting it breaks the run. Every NEW env var must
# be registered in scripts/lib/env.mjs first (RT_ prefix for runtypes-owned vars).

# === Secrets (only needed to run that task from your machine; GitHub secrets in CI) ===
# GHCR push/pull: a GitHub PAT (write:packages to push, read:packages for a private pull).
GHCR_PAT=
# npm publish from local (scripts/release/publish.mjs). CI stage-publishes via
# Trusted Publishing / OIDC and needs no token:
# NPM_TOKEN=
# Cloudflare Pages deploy (a token with "Cloudflare Pages: Edit"):
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# Pages project name (not a secret; CI sets it in website-deploy.yml). Default: runtypes
# CLOUDFLARE_PAGES_PROJECT=runtypes

# === GHCR coordinates (defaults already target this repo) ===
# GHCR_OWNER=mionkit
# GHCR_USER=
# GHCR_REGISTRY=ghcr.io

# === Image source (uncomment to BUILD/USE a local image instead of pulling from GHCR) ===
# RT_WEBSITE_USE_LOCAL=1
# RT_BENCH_USE_LOCAL=1

# === Docs website knobs (scripts/website/site.sh) ===
# RT_WEBSITE_ENGINE=podman
# RT_WEBSITE_IMAGE=tsrt-website:dev
# RT_WEBSITE_CONTAINER=tsrt-website
# RT_WEBSITE_PORT=3000
# RT_WEBSITE_AGENT_PORT=3100
# RT_WEBSITE_AGENT_IDLE_SECONDS=300
# RT_WEBSITE_POLL=1                # fs polling for watchers (default 1 on macOS, 0 on Linux)
# RT_WEBSITE_REPO_CONTEXT=         # host checkout with packages/ (default this repo)
# RT_WEBSITE_DOCDATA=.docdata
# RT_WEBSITE_SKIP_PLAYGROUND=1
# RT_WEBSITE_MOUNT_OPTS=           # e.g. :z on SELinux
# RT_WEBSITE_RUN_NETWORK=          # e.g. host behind a proxy
# RT_WEBSITE_BUILD_NETWORK=
# RT_WEBSITE_BASE_IMAGE=node:26-bookworm
# RT_WEBSITE_PNPM_VERSION=
# RT_WEBSITE_CA_CERT=              # extra CA certs (corporate/MITM proxy)
# RT_WEBSITE_REMOTE_IMAGE=
# RT_WEBSITE_SMOKE_TIMEOUT=90

# === Benchmark knobs (scripts/website/bench-data/bench.sh) ===
# RT_BENCH_NO_TYPIA=1             # skip the typia competitor
# RT_BENCH_QUICK=1                # fast/preview numbers (noisy)
# RT_BENCH_ENGINE=podman
# RT_BENCH_IMAGE=tsrt-website:dev
# RT_BENCH_CONTAINER=tsrt-bench
# RT_BENCH_NO_TIMING=1            # correctness-only
# RT_BENCH_TIME_MS=100            # per-cell timing window (ms)
# RT_BENCH_CASE=                  # restrict to matching case names
# RT_BENCH_DUMP=                  # print typecost probe sources
# RT_BENCH_SERIALIZATION_OUT=
# RT_COMPILETIME_N=5
# RT_COMPILETIME_COMPETITORS=ts-runtypes typia
# RT_TRANSFORM_WIRE_N=5
# RT_BENCH_DOCDATA=.docdata
# RT_BENCH_REMOTE_IMAGE=
# RT_BENCH_MOUNT_OPTS=
# RT_BENCH_RUN_NETWORK=
# RT_BENCH_BUILD_NETWORK=
# RT_BENCH_BASE_IMAGE=
# RT_BENCH_PNPM_VERSION=
# RT_BENCH_CA_CERT=

# === Fuzz test knobs (pnpm run fuzz:*) ===
# RT_FUZZ_SEED=
# RT_FUZZ_SOAK_MS=60000
# RT_FUZZ_TYPES_SOAK_MS=60000
# RT_FUZZ_SIZE_SOAK_MS=
# RT_FUZZ_ROUNDTRIP_SOAK_MS=
# RT_FUZZ_NONDATA_SOAK_MS=
# RT_FUZZ_ENRICH_SEQUENCES=6
# RT_FUZZ_ENRICH_MAXCMDS=8
# RT_FUZZ_ENRICH_REPLAY=
# RT_FUZZ_I18N_SEQUENCES=6
# RT_FUZZ_I18N_MAXCMDS=10
# RT_FUZZ_I18N_REPLAY=
# RT_FUZZ_TYPEMOD_SEQUENCES=6
# RT_FUZZ_TYPEMOD_MAXSTEPS=8
# RT_FUZZ_TYPEMOD_REPLAY=
# RT_FUZZ_TYPEMOD_REPORT=1
# RT_FUZZ_TYPEMOD_DEBUG=1
# RT_FUZZ_RACE=1
# RT_FUZZ_RACE_ITERATIONS=2
# RT_FUZZ_RACE_FANOUT=6

# === Resolver knobs (the ts-runtypes Go binary) ===
# Internal RT disk-cache override. Unset = the cache follows the tsconfig
# incremental/composite setting (on when incremental, off otherwise). Set a path
# to force it on there, or "" to force it off. For tests/benches/power users.
# RT_CACHE_DIR=

# === Build/release knobs ===
# Attach npm provenance on the CI stage-publish. Off by default: npm refuses
# provenance from a PRIVATE source repo. When this repo is public, set the GitHub
# repo variable RT_NPM_PROVENANCE=1 (this .env line only affects a local publish).
# RT_NPM_PROVENANCE=1

# === Lint knobs (ts-runtypes-devtools OXlint/ESLint plugin) ===
# RT_LINT_PRESPAWN=0

# === Pre-publish e2e knobs (pnpm rtx release e2e) ===
# Point the e2e apps' RunTypes plugin at an in-repo binary for host iteration.
# Leave unset in-container / in CI so the PUBLISHED @ts-runtypes/bin launcher
# resolves the platform binary — exactly what the e2e exists to prove.
# RT_E2E_BINARY=./bin/ts-runtypes

# === Alignment-audit knobs (pnpm run audit:alignment) ===
# RT_AUDIT_OUT_DIR=
# RT_AUDIT_TSX=

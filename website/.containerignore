# Keep the build context tiny and make the isolation boundary explicit: only the
# manifests under _deps/ (named in the Containerfile) and .cacerts/ may enter the
# image. Everything below is either source/config (bind-mounted at run time) or an
# artifact.

# Source directories — bind-mounted at run time, never baked.
app/
content/
public/
server/
scripts/
not-rendered/
tests/

# First-party config — bind-mounted at run time now (no longer baked).
nuxt.config.ts
tsconfig.json
eslint.config.mjs

# Build artifacts / caches / deps — must never enter the image.
node_modules/
.nuxt/
.output/
.data/
.cache/
.nitro/
dist/
test-results/

# Editor / VCS / misc
.git/
.vscode-extension/
*.log
*.tgz

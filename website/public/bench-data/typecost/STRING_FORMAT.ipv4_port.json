{"competitors":[{"name":"ts-run-types (type)","source":"{build: () => createValidate<FormatIPv4WithPort>(), buildErrors: () => noErrs(createGetValidationErrors<FormatIPv4WithPort>())}"},{"name":"ts-run-types (schema)","source":"() => createValidate(RT.ipv4WithPort())"},{"name":"typia","source":"{\n    build: () => {\n      const check = typia.createIs<\n        string &\n          tags.Pattern<'^(?:(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9]?[0-9])\\\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9]?[0-9]):(?:6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3}|0)$'>\n      >();\n      return (v) => check(v);\n    },\n    buildErrors: () => {\n      const val = typia.createValidate<\n        string &\n          tags.Pattern<'^(?:(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9]?[0-9])\\\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9][0-9]|[1-9]?[0-9]):(?:6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[1-9][0-9]{0,3}|0)$'>\n      >();\n      return (v) => val(v).success;\n    },\n  }"},{"name":"typebox","source":"c(\n    Type.String({pattern: `^${IPV4_PAT}:${PORT_PAT}$`})\n  )"},{"name":"zod","source":"c(z.string().regex(/^(\\d{1,3}\\.){3}\\d{1,3}:\\d+$/).refine((s) => {\n    const [ip, portStr] = s.split(':');\n    const port = +portStr;\n    if (port < 0 || port > 65535) return false;\n    return ip.split('.').every((o) => +o >= 0 && +o <= 255);\n  }))"}]}